PORT=3001
NEON_DATABASE_URL=postgresql://username:password@your-neon-host.neon.tech/dbname?sslmode=require

OTP_EXPIRY_MINUTES=10
SESSION_TTL_DAYS=30
OTP_SECRET=replace-with-a-random-secret
SESSION_SECRET=replace-with-a-different-random-secret

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
MAIL_FROM=SipUp <your-email@example.com>

CORS_ORIGIN=*
